# ==============================================================================
# ملخص متغيرات البيئة لسكربت تقييم الفيديو عبر Gemini API
# ==============================================================================

# مفتاح API الخاص بـ Google Gemini (مطلوب)
GEMINI_API_KEY=ضع_مفتاح_API_الخاص_بك_هنا

# مسار ملف الفيديو المدخل (افتراضي: /app/data/input_video.mp4)
VIDEO_PATH=./data/input_video.mp4

# مسار التقرير النهائي الناتج (افتراضي: /app/data/qa_report.txt)
OUTPUT_FILE=./data/qa_report.txt

# (اختياري) رابط تحميل مباشر للفيديو من SharePoint/OneDrive
VIDEO_URL=

# (اختياري) مسار ملف الكوكيز في حال كان الرابط محمياً بمصادقة
COOKIES_FILE=./data/cookies.txt

# اسم موديل Gemini المفضل للاستخدام (افتراضي: gemini-3.5-flash)
MODEL_NAME=gemini-3.5-flash

# وضع معالجة الوسائط (auto / audio / video)
# auto: يحاول استخراج الصوت أولاً، وإن فشل يرفع الفيديو بالكامل (الافتراضي)
# audio: يستخرج الصوت ويرفعه فقط (توفيراً للتوكنز)، ويفشل إذا تعذر الاستخراج
# video: يرفع الفيديو بالكامل مباشرة دون محاولة استخراج الصوت
PROCESSING_MODE=auto

# مسار ملف تتبع استهلاك الكوتة التراكمية اليومية ومدى الحياة
USAGE_TRACKER_FILE=./data/gemini_usage_tracker.json
